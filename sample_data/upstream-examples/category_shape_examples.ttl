@prefix : <http://w3id.org/mobilitydcat-ap#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#=============================================================
# VALID EXAMPLES
#=============================================================

#  EXAMPLE 1: Complete Valid Category
# This example includes both mandatory and optional properties
:TrafficCategory a skos:Concept ;
    # Mandatory property
    skos:prefLabel "Traffic Data"@en, "Verkehrsdaten"@de ;
    
    # Optional property
    skos:inScheme :MobilityThemes .

#  EXAMPLE 2: Minimally Valid Category
# This example includes only the mandatory property
:ParkingCategory a skos:Concept ;
    skos:prefLabel "Parking Information"@en .

#  EXAMPLE 3: Category with Multiple Languages
:WeatherCategory a skos:Concept ;
    skos:prefLabel "Weather Conditions"@en, 
                  "Wetterbedingungen"@de,
                  "Conditions météorologiques"@fr ;
    skos:inScheme :MobilityThemes .

#=============================================================
# INVALID EXAMPLES
#=============================================================

# ❌ EXAMPLE 4: Missing Mandatory Property
:InvalidCategory1 a skos:Concept ;
    # Missing skos:prefLabel (mandatory)
    skos:inScheme :MobilityThemes .

# ❌ EXAMPLE 5: Invalid Category Scheme Type
:InvalidCategory2 a skos:Concept ;
    skos:prefLabel "Public Transport"@en ;
    # Category scheme should be a skos:ConceptScheme, not a literal
    skos:inScheme "Mobility Themes" .

# ❌ EXAMPLE 6: Multiple Category Schemes
:InvalidCategory3 a skos:Concept ;
    skos:prefLabel "Road Safety"@en ;
    # Category can belong to at most one scheme (maxCount 1)
    skos:inScheme :MobilityThemes ;
    skos:inScheme :SafetyThemes .

#=============================================================
# SUPPORTING RESOURCES
#=============================================================

# Category Schemes
:MobilityThemes a skos:ConceptScheme ;
    dct:title "Mobility Data Themes"@en ;
    dct:description "Classification scheme for mobility data categories"@en .

:SafetyThemes a skos:ConceptScheme ;
    dct:title "Safety-related Themes"@en ;
    dct:description "Classification scheme for safety-related data categories"@en .

# Dataset using the categories (for context)
:TrafficDataset a dcat:Dataset ;
    dct:title "Real-time Traffic Flow Data"@en ;
    dcat:theme :TrafficCategory, :WeatherCategory .

:ParkingDataset a dcat:Dataset ;
    dct:title "City Parking Availability"@en ;
    dcat:theme :ParkingCategory .
