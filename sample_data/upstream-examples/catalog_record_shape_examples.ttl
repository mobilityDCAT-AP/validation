@prefix : <http://w3id.org/mobilitydcat-ap#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#=============================================================
# VALID EXAMPLES
#=============================================================

#  EXAMPLE 1: Complete Valid Catalogue
# This example includes all mandatory properties and some recommended ones
:GermanMobilityPortal a dcat:Catalog ;
    # Mandatory properties
    dct:title "German Mobility Data Portal"@en, "Deutsches Mobilitätsdatenportal"@de ;
    dct:description "Central access point for mobility data in Germany"@en, "Zentraler Zugangspunkt für Mobilitätsdaten in Deutschland"@de ;
    foaf:homepage <https://mobilitydata.de> ;
    dct:publisher :GermanTransportMinistry ;
    dct:spatial <http://publications.europa.eu/resource/authority/country/DEU> ;
    dcat:dataset :TrafficFlowDataset, :ParkingDataset ;
    dcat:record :TrafficFlowRecord, :ParkingRecord ;
    
    # Recommended properties
    dct:language <http://publications.europa.eu/resource/authority/language/DEU>, 
                 <http://publications.europa.eu/resource/authority/language/ENG> ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    dct:issued "2023-01-15"^^xsd:date ;
    dct:modified "2024-03-10"^^xsd:dateTime ;
    dcat:themeTaxonomy :MobilityThemes ;
    
    # Optional properties
    dct:identifier "DE-MDP-001" ;
    adms:identifier [
        a adms:Identifier ;
        skos:notation "EU-NAP-DE-001" ;
        adms:schemeAgency "European Commission"
    ] ;
    dct:hasPart :BavarianRegionalPortal ;
    dct:isPartOf :EuropeanMobilityDataspace .

#  EXAMPLE 2: Minimally Valid Catalogue
# This example includes only the mandatory properties
:MinimalPortal a dcat:Catalog ;
    dct:title "Basic Mobility Portal" ;
    dct:description "Simple access point for mobility data" ;
    foaf:homepage <https://basic-mobility.org> ;
    dct:publisher :BasicPublisher ;
    dct:spatial <http://publications.europa.eu/resource/authority/country/FRA> ;
    dcat:dataset :BasicDataset ;
    dcat:record :BasicRecord .

#  EXAMPLE 3: Referenced Catalogues (now properly defined)
:BavarianRegionalPortal a dcat:Catalog ;
    dct:title "Bavarian Regional Mobility Portal" ;
    dct:description "Regional access point for mobility data in Bavaria" ;
    foaf:homepage <https://bavaria-mobility.de> ;
    dct:publisher :BavarianTransportMinistry ;
    dct:spatial <http://publications.europa.eu/resource/authority/country/DEU> ;
    dcat:dataset :BavarianTrafficDataset ;
    dcat:record :BavarianTrafficRecord .
    
:EuropeanMobilityDataspace a dcat:Catalog ;
    dct:title "European Mobility Dataspace" ;
    dct:description "Pan-European mobility data sharing platform" ;
    foaf:homepage <https://europe-mobility.eu> ;
    dct:publisher :EuropeanCommission ;
    dct:spatial <http://publications.europa.eu/resource/authority/country/BEL> ;
    dcat:dataset :EuropeanTrafficDataset ;
    dcat:record :EuropeanTrafficRecord .

#=============================================================
# INVALID EXAMPLES
#=============================================================

# ❌ EXAMPLE 4: Missing Mandatory Properties
# This example is missing several mandatory properties
:InvalidPortal1 a dcat:Catalog ;
    dct:title "Incomplete Portal" ;
    dct:description "This catalogue is missing mandatory properties" ;
    # Missing foaf:homepage (mandatory)
    # Missing dct:publisher (mandatory)
    # Missing dct:spatial (mandatory)
    # Missing dcat:dataset (mandatory)
    # Missing dcat:record (mandatory)
    dct:issued "2024-01-01"^^xsd:date .

# ❌ EXAMPLE 5: Invalid Homepage Format
:InvalidPortal2 a dcat:Catalog ;
    dct:title "Invalid Homepage Portal" ;
    dct:description "This catalogue has an invalid homepage format" ;
    # Homepage should be a resource, not a literal string
    foaf:homepage "www.mobility-portal.com" ;
    dct:publisher :BasicPublisher ;
    dct:spatial <http://publications.europa.eu/resource/authority/country/ESP> ;
    dcat:dataset :BasicDataset ;
    dcat:record :BasicRecord .

# ❌ EXAMPLE 6: Multiple Publishers (Cardinality Violation)
:InvalidPortal3 a dcat:Catalog ;
    dct:title "Multiple Publishers Portal" ;
    dct:description "This catalogue has multiple publishers" ;
    foaf:homepage <https://multi-publisher.org> ;
    # Publisher can appear at most once (maxCount 1)
    dct:publisher :Publisher1 ;
    dct:publisher :Publisher2 ;
    dct:spatial <http://publications.europa.eu/resource/authority/country/ITA> ;
    dcat:dataset :BasicDataset ;
    dcat:record :BasicRecord .

# ❌ EXAMPLE 7: Invalid Date Format
:InvalidPortal4 a dcat:Catalog ;
    dct:title "Invalid Date Format Portal" ;
    dct:description "This catalogue has an invalid date format" ;
    foaf:homepage <https://date-format.org> ;
    dct:publisher :BasicPublisher ;
    dct:spatial <http://publications.europa.eu/resource/authority/country/BEL> ;
    dcat:dataset :BasicDataset ;
    dcat:record :BasicRecord ;
    # Date should be xsd:date or xsd:dateTime, not a string
    dct:issued "January 15, 2024" .

#=============================================================
# SUPPORTING RESOURCES
#=============================================================

# Homepage URLs declared as foaf:Document
<https://mobilitydata.de> a rdfs:Resource .
<https://basic-mobility.org> a rdfs:Resource .
<https://bavaria-mobility.de> a rdfs:Resource .
<https://europe-mobility.eu> a rdfs:Resource .
<https://multi-publisher.org> a rdfs:Resource .
<https://date-format.org> a rdfs:Resource .

# Agents
:GermanTransportMinistry a foaf:Agent ;
    foaf:name "Federal Ministry of Transport and Digital Infrastructure" .

:BasicPublisher a foaf:Agent ;
    foaf:name "Basic Mobility Organization" .

:BavarianTransportMinistry a foaf:Agent ;
    foaf:name "Bavarian Ministry of Transport" .
    
:EuropeanCommission a foaf:Agent ;
    foaf:name "European Commission" .

:Publisher1 a foaf:Agent ;
    foaf:name "First Publisher" .

:Publisher2 a foaf:Agent ;
    foaf:name "Second Publisher" .

# Datasets
:TrafficFlowDataset a dcat:Dataset .
:ParkingDataset a dcat:Dataset .
:BasicDataset a dcat:Dataset .
:BavarianTrafficDataset a dcat:Dataset .
:EuropeanTrafficDataset a dcat:Dataset .

# Catalog Records
:TrafficFlowRecord a dcat:CatalogRecord .
:ParkingRecord a dcat:CatalogRecord .
:BasicRecord a dcat:CatalogRecord .
:BavarianTrafficRecord a dcat:CatalogRecord .
:EuropeanTrafficRecord a dcat:CatalogRecord .

# Other Resources
:MobilityThemes a skos:ConceptScheme .
<https://creativecommons.org/licenses/by/4.0/> a dct:LicenseDocument .

# Locations
<http://publications.europa.eu/resource/authority/country/DEU> a dct:Location .
<http://publications.europa.eu/resource/authority/country/FRA> a dct:Location .
<http://publications.europa.eu/resource/authority/country/BEL> a dct:Location .
<http://publications.europa.eu/resource/authority/country/ESP> a dct:Location .
<http://publications.europa.eu/resource/authority/country/ITA> a dct:Location .

# Language Systems
<http://publications.europa.eu/resource/authority/language/DEU> a dct:LinguisticSystem .
<http://publications.europa.eu/resource/authority/language/ENG> a dct:LinguisticSystem .
