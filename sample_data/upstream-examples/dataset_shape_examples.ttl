@prefix : <http://w3id.org/mobilitydcat-ap#> .
@prefix mobilitydcatap: <http://w3id.org/mobilitydcat-ap#> .
@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcatap: <http://data.europa.eu/r5r/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dqv: <http://www.w3.org/ns/dqv#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix oa: <http://www.w3.org/ns/oa#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#=============================================================
# WHAT IS A DATASET?
#=============================================================
# A Dataset in mobilityDCAT-AP represents a collection of data related to 
# mobility and transportation. It extends the DCAT-AP Dataset class with
# properties specific to mobility data, such as transport modes, 
# mobility themes, and georeference methods.

#=============================================================
# VALID EXAMPLES
#=============================================================

#  EXAMPLE 1: Complete Mobility Dataset with All Key Properties
# This example shows a traffic dataset with all recommended mobility properties
:CologneTrafficDataset a dcat:Dataset ;
    # Mandatory property - describes the general theme of mobility data
    mobilitydcatap:mobilityTheme <https://w3id.org/mobilitydcat-ap/mobility-theme/traffic-data> ;
    
    # Method used for geographic referencing of the data
    mobilitydcatap:georeferencingMethod <https://w3id.org/mobilitydcat-ap/georeferencing-method/linear-referencing> ;
    
    # Describes what parts of the transport network are covered
    mobilitydcatap:networkCoverage <https://w3id.org/mobilitydcat-ap/network-coverage/urban-roads> ;
    
    # Coordinate reference system used for the data
    dct:conformsTo <http://www.opengis.net/def/crs/EPSG/0/25832> ;
    
    # Organization that owns rights to the data
    dct:rightsHolder [
        a foaf:Agent ;
        foaf:name "Stadt Köln - Amt für Verkehrsmanagement" ;
        foaf:mbox <mailto:verkehrsmanagement@stadt-koeln.de>
    ] ;
    
    # Transport mode the data relates to
    mobilitydcatap:transportMode <https://w3id.org/mobilitydcat-ap/transport-mode/road> ;
    
    # EU legislation that applies to this data
    dcatap:applicableLegislation <http://data.europa.eu/eli/reg_del/2015/962/oj> ;
    
    # Assessment of compliance with standards
    mobilitydcatap:assessmentResult [
        a mobilitydcatap:Assessment ;
        dct:description "Compliant with EU RTTI Delegated Regulation standards"@en
    ] ;
    
    # Information service this data is intended for
    mobilitydcatap:intentedInformationService <https://w3id.org/mobilitydcat-ap/intended-information-service/real-time-traffic> ;
    
    # Quality annotations about the data's availability
    dqv:hasQualityAnnotation [
        a dqv:QualityAnnotation ;
        dqv:inDimension dqv:Availability ;
        dct:description "Traffic data update frequency: Every 5 minutes, 98.5% system availability"@en
    ] .

#  EXAMPLE 2: Minimal Valid Dataset with Only Mandatory Properties
# This example shows the minimum required properties for a valid dataset
:MinimalTransitDataset a dcat:Dataset ;
    # Only the mobilityTheme property is mandatory
    mobilitydcatap:mobilityTheme <https://w3id.org/mobilitydcat-ap/mobility-theme/public-transport> .

#  EXAMPLE 3: Dataset with Multiple Transport Modes
# This example shows a dataset that covers multiple transport modes
:CologneTransitDataset a dcat:Dataset ;
    mobilitydcatap:mobilityTheme <https://w3id.org/mobilitydcat-ap/mobility-theme/public-transport> ;
    mobilitydcatap:georeferencingMethod <https://w3id.org/mobilitydcat-ap/georeferencing-method/stop-point> ;
    # Multiple transport modes can be specified
    mobilitydcatap:transportMode <https://w3id.org/mobilitydcat-ap/transport-mode/bus>,
                                <https://w3id.org/mobilitydcat-ap/transport-mode/tram> ;
    dct:rightsHolder [
        a foaf:Agent ;
        foaf:name "Kölner Verkehrs-Betriebe AG" ;
        foaf:mbox <mailto:opendata@kvb.koeln>
    ] .

#=============================================================
# INVALID EXAMPLES
#=============================================================

# ❌ EXAMPLE 4: Missing Mandatory Theme
# This is invalid because mobilityTheme is mandatory
:DusseldorfParkingDataset a dcat:Dataset ;
    # Missing the mandatory mobilityTheme property
    mobilitydcatap:georeferencingMethod <https://w3id.org/mobilitydcat-ap/georeferencing-method/point-based> ;
    dct:conformsTo <http://www.opengis.net/def/crs/EPSG/0/25832> .

# ❌ EXAMPLE 5: Wrong Theme Pattern
# This is invalid because mobilityTheme must use the controlled vocabulary
:BonnPTDataset a dcat:Dataset ;
    # Theme must use the official mobilityDCAT-AP vocabulary URI pattern
    mobilitydcatap:mobilityTheme <http://example.org/public-transport> ;
    mobilitydcatap:transportMode <https://w3id.org/mobilitydcat-ap/transport-mode/bus> .

# ❌ EXAMPLE 6: Invalid Quality Annotation
# This is invalid because quality annotations must be resources, not literals
:InvalidHamburgPortDataset a dcat:Dataset ;
    mobilitydcatap:mobilityTheme <https://w3id.org/mobilitydcat-ap/mobility-theme/freight-transport> ;
    # Quality annotation should be a dqv:QualityAnnotation resource, not a literal
    dqv:hasQualityAnnotation "High quality real-time data" .

# ❌ EXAMPLE 7: Invalid Rights Holder
# This is invalid because rightsHolder should be a foaf:Agent, not a literal
:AachenChargingDataset a dcat:Dataset ;
    mobilitydcatap:mobilityTheme <https://w3id.org/mobilitydcat-ap/mobility-theme/charging-infrastructure> ;
    # Rights holder should be a foaf:Agent resource, not a literal string
    dct:rightsHolder "City of Aachen" .

#=============================================================
# VALIDATION RULES SUMMARY
#=============================================================
# 1. MANDATORY: Each dataset MUST have at least one mobilitydcatap:mobilityTheme
# 2. mobilityTheme values MUST use the controlled vocabulary from mobilityDCAT-AP
# 3. If used, dqv:hasQualityAnnotation MUST link to a dqv:QualityAnnotation resource
# 4. If used, dct:rightsHolder MUST link to a foaf:Agent resource
# 5. If used, mobilitydcatap:assessmentResult MUST link to a mobilitydcatap:Assessment resource
