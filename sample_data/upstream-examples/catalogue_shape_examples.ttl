@prefix : <http://w3id.org/mobilitydcat-ap#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#=============================================================
# VALID EXAMPLES
#=============================================================

#  EXAMPLE 1: Complete Valid Catalogue Record
# This example includes all mandatory properties and some optional ones
:TrafficFlowRecord a dcat:CatalogRecord ;
    # Mandatory properties
    dct:created "2023-01-15T10:30:00"^^xsd:dateTime ;
    dct:language <http://publications.europa.eu/resource/authority/language/ENG>,
                 <http://publications.europa.eu/resource/authority/language/DEU> ;
    foaf:primaryTopic :TrafficFlowDataset ;
    dct:modified "2024-02-20T15:45:00"^^xsd:dateTime ;
    
    # Optional properties
    dct:publisher :MetadataTeam ;
    dct:source :OriginalTrafficRecord .

#  EXAMPLE 2: Minimally Valid Catalogue Record
# This example includes only the mandatory properties
:MinimalRecord a dcat:CatalogRecord ;
    dct:created "2023-05-10"^^xsd:date ;
    dct:language <http://publications.europa.eu/resource/authority/language/ENG> ;
    foaf:primaryTopic :BasicDataset ;
    dct:modified "2023-05-10"^^xsd:date .

#  EXAMPLE 3: Valid Record with Same Creation and Modification Date
:NewRecord a dcat:CatalogRecord ;
    dct:created "2024-03-01"^^xsd:date ;
    dct:language <http://publications.europa.eu/resource/authority/language/FRA> ;
    foaf:primaryTopic :FrenchDataset ;
    # Uses same date as creation date (as specified in documentation)
    dct:modified "2024-03-01"^^xsd:date .

#  EXAMPLE 4: Original Traffic Record (now properly defined)
:OriginalTrafficRecord a dcat:CatalogRecord ;
    dct:created "2022-10-05"^^xsd:date ;
    dct:language <http://publications.europa.eu/resource/authority/language/ENG> ;
    foaf:primaryTopic :OriginalDataset ;
    dct:modified "2022-11-15"^^xsd:date ;
    dct:publisher :OriginalPublisher .

#=============================================================
# INVALID EXAMPLES
#=============================================================

# ❌ EXAMPLE 5: Missing Mandatory Properties
:InvalidRecord1 a dcat:CatalogRecord ;
    dct:created "2023-01-15"^^xsd:date ;
    # Missing dct:language (mandatory)
    # Missing foaf:primaryTopic (mandatory)
    # Missing dct:modified (mandatory)
    dct:publisher :MetadataTeam .

# ❌ EXAMPLE 6: Invalid Date Format
:InvalidRecord2 a dcat:CatalogRecord ;
    # Invalid date format (should be xsd:date or xsd:dateTime)
    dct:created "January 15, 2023" ;
    dct:language <http://publications.europa.eu/resource/authority/language/ENG> ;
    foaf:primaryTopic :BasicDataset ;
    dct:modified "2023-02-20"^^xsd:date .

# ❌ EXAMPLE 7: Multiple Primary Topics (Cardinality Violation)
:InvalidRecord3 a dcat:CatalogRecord ;
    dct:created "2023-01-15"^^xsd:date ;
    dct:language <http://publications.europa.eu/resource/authority/language/ENG> ;
    # Primary topic can appear at most once (maxCount 1)
    foaf:primaryTopic :Dataset1 ;
    foaf:primaryTopic :Dataset2 ;
    dct:modified "2023-02-20"^^xsd:date .

# ❌ EXAMPLE 8: Invalid Source Type
:InvalidRecord4 a dcat:CatalogRecord ;
    dct:created "2023-01-15"^^xsd:date ;
    dct:language <http://publications.europa.eu/resource/authority/language/ENG> ;
    foaf:primaryTopic :BasicDataset ;
    dct:modified "2023-02-20"^^xsd:date ;
    # Source should be a dcat:CatalogRecord, not a string
    dct:source "Original metadata from city portal" .

#=============================================================
# SUPPORTING RESOURCES
#=============================================================

# Datasets
:TrafficFlowDataset a dcat:Dataset .
:BasicDataset a dcat:Dataset .
:FrenchDataset a dcat:Dataset .
:OriginalDataset a dcat:Dataset .
:Dataset1 a dcat:Dataset .
:Dataset2 a dcat:Dataset .

# Publishers
:MetadataTeam a foaf:Agent ;
    foaf:name "Metadata Management Team" ;
    foaf:mbox <mailto:metadata@example.org> .

:OriginalPublisher a foaf:Agent ;
    foaf:name "Original Data Provider" ;
    foaf:mbox <mailto:provider@example.org> .

# Languages
<http://publications.europa.eu/resource/authority/language/ENG> a dct:LinguisticSystem .
<http://publications.europa.eu/resource/authority/language/DEU> a dct:LinguisticSystem .
<http://publications.europa.eu/resource/authority/language/FRA> a dct:LinguisticSystem .
