@prefix : <http://w3id.org/mobilitydcat-ap#> .
@prefix mobilitydcatap: <http://w3id.org/mobilitydcat-ap#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

#=============================================================
# WHAT IS A MOBILITY DATA STANDARD?
#=============================================================
# A Mobility Data Standard in mobilityDCAT-AP represents a formal specification
# used for mobility data. It can include version information and reference to
# a schema. These standards define how mobility data is formatted and structured,
# ensuring interoperability between different systems and services.

#=============================================================
# VALID EXAMPLES
#=============================================================

#  EXAMPLE 1: Standard with Both Properties
# This example shows a standard with both version and schema properties
:ValidStandard1 a mobilitydcatap:MobilityDataStandard ;
    # Version of the standard as a simple string
    owl:versionInfo "3.2" ;
    
    # Reference to a schema resource
    mobilitydcatap:schema :Schema1 .

# The schema must be a resource
:Schema1 a rdfs:Resource .

#  EXAMPLE 2: Standard with Only Version
# This example shows a standard with just the version property
:ValidStandard2 a mobilitydcatap:MobilityDataStandard ;
    # Only version information, schema is optional
    owl:versionInfo "2.0" .

#  EXAMPLE 3: Standard with Only Schema Reference
# This example shows a standard with just the schema property
:ValidStandard3 a mobilitydcatap:MobilityDataStandard ;
    # Only schema reference, version is optional
    mobilitydcatap:schema <http://datex2.eu/profiles/urban-traffic> .

#=============================================================
# INVALID EXAMPLES
#=============================================================

# ❌ EXAMPLE 4: Multiple Version Properties
# This is invalid because only one version property is allowed
:InvalidStandard1 a mobilitydcatap:MobilityDataStandard ;
    # Multiple version properties violate maxCount 1 constraint
    owl:versionInfo "3.2" ;
    owl:versionInfo "3.3" ;
    mobilitydcatap:schema :Schema3 .

:Schema3 a rdfs:Resource .

# ❌ EXAMPLE 5: Complex Version Format
# This may be rejected by some validators due to non-simple version format
:InvalidStandard2 a mobilitydcatap:MobilityDataStandard ;
    # Version should be simple and concise, without redundant text
    owl:versionInfo "DATEX II v3.2" ;
    mobilitydcatap:schema :Schema4 .

:Schema4 a rdfs:Resource .

# ❌ EXAMPLE 6: Schema as Literal Instead of Resource
# This is invalid because schema must be a resource, not a literal
:InvalidStandard3 a mobilitydcatap:MobilityDataStandard ;
    owl:versionInfo "4.0" ;
    # Schema must be a resource (URI or blank node), not a literal string
    mobilitydcatap:schema "http://example.org/schemas/datex2-v4.0" .

#=============================================================
# VALIDATION RULES SUMMARY
#=============================================================
# 1. owl:versionInfo MUST have at most one value (maxCount 1)
# 2. If used, owl:versionInfo SHOULD be a simple version string
# 3. mobilitydcatap:schema MUST have at most one value (maxCount 1)
# 4. If used, mobilitydcatap:schema MUST be a resource (instance of rdfs:Resource)
# 5. Both properties are optional, but at least one is recommended
