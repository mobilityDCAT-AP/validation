@prefix : <http://w3id.org/mobilitydcat-ap#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

#=============================================================
# WHAT IS A LICENSE DOCUMENT?
#=============================================================
# A License Document in mobilityDCAT-AP describes the legal terms under which
# mobility data can be accessed and used. It provides information about 
# permissions, restrictions, and requirements for data usage. License documents
# typically include identifiers referencing standard licenses and descriptive labels.

#=============================================================
# VALID EXAMPLES
#=============================================================

#  EXAMPLE 1: Public EU Open Data License
# This example shows a license document with a standard EU identifier
:EUOpenDataLicense a dct:LicenseDocument ;
    # Reference to a standardized EU license identifier
    dct:identifier <http://publications.europa.eu/resource/authority/access-right/PUBLIC> ;
    
    # Human-readable description of the license terms
    rdfs:label "This dataset is provided under the EU Open Data License. Free to use with attribution to the data provider."@en .

#  EXAMPLE 2: Non-Public Research License
# This example shows a more restrictive license for research use
:FraunhoferResearchLicense a dct:LicenseDocument ;
    dct:identifier <http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC> ;
    rdfs:label "For research and academic use only. Contact Fraunhofer FIT for commercial usage rights."@en .

#  EXAMPLE 3: Custom Municipal License
# This example shows a license without a standard identifier
:CologneOpenDataLicense a dct:LicenseDocument ;
    # License document can exist with just a label
    rdfs:label "Diese Daten werden unter der Datenlizenz Deutschland – Namensnennung – Version 2.0 bereitgestellt. Siehe: www.govdata.de/dl-de/by-2-0"@de .

#=============================================================
# INVALID EXAMPLES
#=============================================================

# ❌ EXAMPLE 4: Wrong Pattern for Identifier
# This is invalid because it uses a non-standard identifier pattern
:InvalidMobilityLicense1 a dct:LicenseDocument ;
    # Should use the standard EU publications authority pattern
    dct:identifier <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:label "Creative Commons Attribution 4.0 International License"@en .

# ❌ EXAMPLE 5: Multiple Identifiers
# This is invalid because only one identifier is allowed
:InvalidMobilityLicense2 a dct:LicenseDocument ;
    # Only one identifier is allowed (maxCount 1)
    dct:identifier <http://publications.europa.eu/resource/authority/access-right/PUBLIC>,
                  <http://publications.europa.eu/resource/authority/access-right/RESTRICTED> ;
    rdfs:label "Mixed Access License"@en .

# ❌ EXAMPLE 6: Multiple Labels
# This is invalid because only one label is allowed
:InvalidMobilityLicense3 a dct:LicenseDocument ;
    dct:identifier <http://publications.europa.eu/resource/authority/access-right/PUBLIC> ;
    # Only one label is allowed (maxCount 1)
    rdfs:label "Public Transport Data License"@en,
              "Lizenz für ÖPNV-Daten"@de .

# ❌ EXAMPLE 7: Non-literal Label
# This is invalid because label must be a literal string
:InvalidMobilityLicense4 a dct:LicenseDocument ;
    dct:identifier <http://publications.europa.eu/resource/authority/access-right/PUBLIC> ;
    # Label must be a literal string, not a URI
    rdfs:label <http://example.org/license-text> .

#=============================================================
# VALIDATION RULES SUMMARY
#=============================================================
# 1. dct:identifier MUST have at most one value (maxCount 1)
# 2. If used, dct:identifier SHOULD follow the EU publications authority pattern
# 3. rdfs:label MUST have at most one value (maxCount 1)
# 4. If used, rdfs:label MUST be a literal string with language tag
# 5. Either dct:identifier or rdfs:label SHOULD be provided
