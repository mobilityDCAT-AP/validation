@prefix : <http://w3id.org/mobilitydcat-ap#> .
@prefix mobilitydcatap: <http://w3id.org/mobilitydcat-ap#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix oa: <http://www.w3.org/ns/oa#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#=============================================================
# EXAMPLES - Understanding Non-Literal Properties in Assessment Shape
#=============================================================
# 1. **Assessment Date (dct:issued)**
# - This property represents the **date** when the assessment was issued. It can be in two formats: `xsd:date` (e.g., "2024-02-20") or `xsd:dateTime` (e.g., "2024-03-15T14:30:00").
# - This date is a **literal** value in the RDF data but needs to follow the specified **data type** format for it to be valid.
# - Example: The assessment has a date when it was issued, and it must be either a date or a datetime value.

# 2. **Assessment Result (oa:hasBody)**
# - This property links to a **body** resource that describes the content or result of the assessment.
# - The value of `oa:hasBody` can either be a **URL** (pointing to a web page with assessment details) or a **blank node** (which contains RDF data directly within the document).
# - Example: The result of the assessment is described by a URL like `<https://example.org/assessments/traffic-2024>`, or by a blank node containing details such as labels or comments.

# 3. **Blank Node Body (Blank Node)**
# - In the case of Example 3 (`:SafetyAssessment`), the assessment’s body is a **blank node**. This means that the body doesn’t link to an external resource but is described directly in the data.
# - The blank node can contain RDF properties like `rdfs:label` (a label) and `rdfs:comment` (a description or explanation) to provide context or details about the assessment result.
# - Example: A blank node is used for the safety assessment, and it has a label and comment describing the results.

#=============================================================
# VALID EXAMPLES
#=============================================================

#  EXAMPLE 1: Valid Assessment with dateTime
:TrafficAssessment a mobilitydcatap:Assessment ;
    dct:issued "2024-03-15T14:30:00"^^xsd:dateTime ;
    oa:hasBody <https://example.org/assessments/traffic-2024> .

<https://example.org/assessments/traffic-2024> a rdfs:Resource .

#  EXAMPLE 2: Valid Assessment with date
:ParkingAssessment a mobilitydcatap:Assessment ;
    dct:issued "2024-02-20"^^xsd:date ;
    oa:hasBody <https://example.org/assessments/parking-2024> .

<https://example.org/assessments/parking-2024> a rdfs:Resource .

#  EXAMPLE 3: Valid Assessment with blank node body
:SafetyAssessment a mobilitydcatap:Assessment ;
    dct:issued "2024-01-10"^^xsd:date ;
    oa:hasBody [
        a rdfs:Resource ;
        rdfs:label "Safety assessment results" ;
        rdfs:comment "This assessment verified compliance with safety regulations" 
    ] .

#  EXAMPLE 4: Valid Assessment with minimal properties
:MinimalAssessment a mobilitydcatap:Assessment .

#=============================================================
# INVALID EXAMPLES
#=============================================================

# ❌ EXAMPLE 5: Invalid date format
:InvalidDateAssessment a mobilitydcatap:Assessment ;
    dct:issued "March 15, 2024" ; # Invalid: Not xsd:date or xsd:dateTime
    oa:hasBody <https://example.org/assessments/invalid-date> .

<https://example.org/assessments/invalid-date> a rdfs:Resource .

# ❌ EXAMPLE 6: Multiple issued dates
:MultiDateAssessment a mobilitydcatap:Assessment ;
    dct:issued "2024-03-10"^^xsd:date ;
    dct:issued "2024-03-15"^^xsd:date ; # Invalid: Multiple values violate maxCount 1
    oa:hasBody <https://example.org/assessments/multi-date> .

<https://example.org/assessments/multi-date> a rdfs:Resource .

# ❌ EXAMPLE 7: Multiple body resources
:MultiBodyAssessment a mobilitydcatap:Assessment ;
    dct:issued "2024-04-01"^^xsd:date ;
    oa:hasBody <https://example.org/assessments/part1> ;
    oa:hasBody <https://example.org/assessments/part2> . # Invalid: Multiple values violate maxCount 1

<https://example.org/assessments/part1> a rdfs:Resource .
<https://example.org/assessments/part2> a rdfs:Resource .

# ❌ EXAMPLE 8: Non-resource body
:StringBodyAssessment a mobilitydcatap:Assessment ;
    dct:issued "2024-05-15"^^xsd:date ;
    oa:hasBody "Assessment passed with high score" . # Invalid: String literal instead of rdfs:Resource
