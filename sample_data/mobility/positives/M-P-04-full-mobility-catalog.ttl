@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix locn: <http://www.w3.org/ns/locn#> .
@prefix ex:   <https://example.org/data/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix mobilitydcatap: <https://w3id.org/mobilitydcat-ap/ns#> .

### Catalog
ex:catalog1 a dcat:Catalog ;
    dct:title "National Mobility Data Catalog"@en ;
    dct:publisher ex:agent1 ;
    dct:spatial ex:spatial1 ;
    dcat:record ex:record1 .

### Catalog Record
ex:record1 a dcat:CatalogRecord ;
    foaf:primaryTopic ex:dataset1 ;
    dct:language <http://publications.europa.eu/resource/authority/language/ENG> ;
    dct:created "2024-01-01"^^xsd:date ;
    dct:modified "2025-01-01"^^xsd:date .

### Dataset
ex:dataset1 a dcat:Dataset ;
    dct:title "Public Transport GTFS Feed"@en ;
    dct:description "GTFS schedules for national public transport."@en ;
    dct:publisher ex:agent1 ;
    dcat:distribution ex:distribution1 .

### Distribution
ex:distribution1 a dcat:Distribution ;
    dcat:accessURL <https://example.org/gtfs/gtfs.zip> ;
    dct:format <http://publications.europa.eu/resource/authority/file-type/ZIP> ;
    dct:rights <http://publications.europa.eu/resource/authority/access-right/PUBLIC> ;
    mobilitydcatap:mobilityDataStandard
        <http://publications.europa.eu/resource/authority/mobility-data-standard/GTFS> .

### Agent
ex:agent1 a foaf:Agent ;
    foaf:name "National Transport Authority"@en .

### Spatial
ex:spatial1 a dct:Location ;
    locn:geometry "POLYGON((10 45, 15 45, 15 50, 10 50, 10 45))"^^<http://www.opengis.net/ont/geosparql#wktLiteral> .

