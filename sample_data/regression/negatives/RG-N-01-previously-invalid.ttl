@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ex:   <https://example.org/data/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Catalog missing publisher and distribution accessURL
ex:catalog1 a dcat:Catalog ;
    dct:title "Mobility Data Portal"@en ;
    dct:description "A portal for mobility-related datasets."@en ;
    foaf:homepage <https://example.org/> ;
    dcat:record ex:record1 ;
    dct:spatial <https://example.org/location/DE> .

ex:record1 a dcat:CatalogRecord ;
    foaf:primaryTopic ex:dataset1 ;
    dct:created "2025-01-01"^^xsd:date ;
    dct:modified "2025-01-02"^^xsd:date .

ex:dataset1 a dcat:Dataset ;
    dct:title "Sample Dataset"@en ;
    dcat:distribution ex:distribution1 .

ex:distribution1 a dcat:Distribution ;
    dct:format <http://publications.europa.eu/resource/authority/file-type/CSV> ;
    dct:rights <http://publications.europa.eu/resource/authority/access-right/PUBLIC> .
