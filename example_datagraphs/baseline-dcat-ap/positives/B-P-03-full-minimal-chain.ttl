@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:   <https://example.org/data/> .
@prefix mobilitydcatap: <https://w3id.org/mobilitydcat-ap#> .

<https://example.org/catalog>
    a dcat:Catalog ;
    dct:title "Full minimal catalog"@en ;
    foaf:homepage <https://examplehomepage.org> ;
    dcat:record <https://example.org/record/1> ;
    dcat:dataset <https://example.org/dataset/1> ;
    dct:spatial ex:spatial1 .

<https://example.org/record/1>
    a dcat:CatalogRecord ;
    foaf:primaryTopic <https://example.org/dataset/1> ;
    dct:language "EN" ;
    dct:created "2024-01-01"^^xsd:date .

<https://example.org/dataset/1>
    a dcat:Dataset ;
    dct:title "Example dataset"@en ;
    dcat:distribution <https://example.org/distribution/1> .

<https://example.org/distribution/1>
    a dcat:Distribution ;
    dct:format "something" ;
    mobilitydcatap:mobilityDataStandard <https://w3id.org/mobilitydcat-ap/mobility-data-standard/c-its> ;
    dcat:accessURL <https://example.org/download/data.csv> .
    