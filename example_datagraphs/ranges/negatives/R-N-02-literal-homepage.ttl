@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ex:   <https://example.org/data/> .

ex:catalog1 a dcat:Catalog ;
    dct:title "Mobility Data Catalog"@en ;
    dct:publisher ex:agent1 ;
    dct:spatial <http://sws.geonames.org/276/> ;
    # This should fail: foaf:homepage must be an IRI
    foaf:homepage "https://example.org/" .

ex:agent1 a foaf:Agent ;
    foaf:name "Transport Authority"@en .
